{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "pilotSlides"
  ],
  "properties": {
    "pilotSlides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slideNumber",
          "primaryReferenceFrameId",
          "primaryReferenceFrameName",
          "visualFidelityScore"
        ],
        "properties": {
          "slideNumber": {
            "type": "integer",
            "minimum": 1
          },
          "primaryReferenceFrameId": {
            "type": "string"
          },
          "primaryReferenceFrameName": {
            "type": "string"
          },
          "visualFidelityScore": {
            "type": "number",
            "minimum": 1,
            "maximum": 5
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
