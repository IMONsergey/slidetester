{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "deck",
    "slides"
  ],
  "properties": {
    "deck": {
      "type": "object",
      "required": [
        "sourcePptx",
        "sourceFigmaFileKey",
        "designRulePriority"
      ],
      "properties": {
        "sourcePptx": {
          "type": "string"
        },
        "sourceFigmaFileKey": {
          "type": "string"
        },
        "designRulePriority": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "slides": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "slideNumber",
          "title",
          "patternId",
          "message"
        ],
        "properties": {
          "slideNumber": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "patternId": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
