{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "generatedFrom",
    "patterns"
  ],
  "properties": {
    "generatedFrom": {
      "type": "object"
    },
    "patterns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "patternId",
          "sourceFrameIds",
          "visualRole"
        ],
        "properties": {
          "patternId": {
            "type": "string"
          },
          "sourceFrameIds": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "visualRole": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
